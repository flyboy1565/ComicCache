# Comic Vine API key for barcode lookup
COMIC_VINE_API_KEY=

# JWT secret for user authentication (generate with: openssl rand -hex 32)
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default admin credentials (used on first run when no admin user exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@comiccache.local
